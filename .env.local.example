# molesignal-website 本地/部署环境变量模板（M1 就绪所需）
# 用法：cp .env.local.example .env.local 后填入真实值（.env.local 已被 Next.js gitignore，不入库）。
# 缺失任一项时对应功能"优雅降级 + 打日志"，但 READINESS 的对应就绪项无法判 [x]（详见 READINESS.md「外部前置一览」）。

# --- Resend：候补 / Design Partner 真入库可触达（T01/T02/T06）---
RESEND_API_KEY=
# 在 Resend 后台建两个 Audience，填其 ID：
RESEND_CLOUD_AUDIENCE_ID=
RESEND_PARTNER_AUDIENCE_ID=
# 接收表单通知的邮箱（缺省有内置默认）：
FOUNDERS_EMAIL=

# --- Upstash Redis：可靠限流（T11，替换内存 Map）---
# 缺失时回退内存 Map（serverless 多实例下不可靠，仅本地够用）。
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Plausible：转化埋点（T05）---
# 你的 Plausible 统计域名，例：molesignal.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --- 社区：Discord 真实邀请链接（T17）---
# 填入真实 Discord 邀请 URL（如 https://discord.gg/xxxx）后，community-callout 与
# Footer 的 Discord 入口自动从"即将上线"诚实禁用态切换为真实外链；留空则保持禁用态。
NEXT_PUBLIC_DISCORD_INVITE_URL=

# --- QuickStart 产物就绪切换（T19）---
# Helm repo（charts.molesignal.io）与预编译二进制 release 真实发布、命令冒烟可执行后，
# 置为 true：/start 的 Helm/binary tab 自动移除"v1.0 target"诚实 notice 并去掉文件名
# "(v1.0 target)"后缀；留空/非 true 则保持当前诚实标注（Docker 路径今日可用）。
NEXT_PUBLIC_QUICKSTART_ARTIFACTS_READY=

# --- GitHub（可选，T07/T16/T20）---
# 仓库 molesignal/molesignal 公开 + 有 Release 时，填只读 token 接真实 stats/contributors/releases；
# 留空则用静态兜底数据 + 诚实标注（当前决策：仓库未公开 → 留空）。
GITHUB_TOKEN=
